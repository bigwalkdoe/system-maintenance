# Auto-detect text files, normalize to LF
* text=auto eol=lf

# Declare files that are always binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.gz binary
*.gpg binary
*.asc binary
*.p12 binary
*.pfx binary

# Linguist overrides — treat generated/config files appropriately
CHANGELOG.md linguist-generated=true
ci-cd/ linguist-vendored
cloud-deployment/ linguist-vendored

# Diff helpers — make structured-file diffs more readable
*.sh diff=bash
*.yml diff=yaml
*.yaml diff=yaml
*.json diff=json
*.tf diff=terraform
*.rego diff=rego
*.py diff=python
